{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git status *": "ask",
      "git diff *": "ask",
      "git log *": "ask",
      "git add *": "ask",
      "git commit *": "ask",
      "git branch *": "ask",
      "git checkout *": "ask",
      "git stash *": "ask",
      "git show *": "ask",
      "git rev-parse *": "ask",
      "git ls-files *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git merge *": "ask",
      "curl *": "deny",
      "wget *": "deny",
      "nc *": "deny",
      "ncat *": "deny",
      "netcat *": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "sftp *": "deny",
      "rsync *": "deny",
      "sudo *": "deny",
      "su *": "deny",
      "doas *": "deny",
      "pkexec *": "deny",
      "runuser *": "deny",
      "newgrp *": "deny",
      "chmod 777 *": "deny",
      "rm -rf *": "deny",
      "mktemp *": "deny",
      "crontab *": "deny",
      "at *": "deny",
      "systemctl *": "deny",
      "service *": "deny",
      "docker *": "deny",
      "podman *": "deny",
      "kubectl *": "deny",
      "terraform *": "deny",
      "aws *": "deny",
      "gcloud *": "deny",
      "az *": "deny",
      "python3 -c *": "deny",
      "python3 -m http.server *": "deny",
      "eval *": "deny",
      "exec *": "deny",
      "source /etc/*": "deny",
      "source ~/.bashrc": "deny",
      "source ~/.zshrc": "deny"
    },
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "**/secrets/**": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.docker/config.json": "deny",
      "~/.netrc": "deny",
      "/etc/passwd": "deny",
      "/etc/shadow": "deny",
      "/etc/sudoers": "deny"
    },
    "edit": {
      "*": "ask",
      ".git/**": "deny",
      "/etc/**": "deny",
      "/usr/**": "deny",
      "/bin/**": "deny",
      "~/.bashrc": "deny",
      "~/.zshrc": "deny",
      "~/.profile": "deny",
      "~/.ssh/**": "deny"
    },
    "webfetch": "deny"
  },
  "share": "disabled"
}
